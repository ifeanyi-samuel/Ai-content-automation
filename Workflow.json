    {
      "parameters": {
        "promptType": "define",
        "text": "=Based on these trending topics:\n{{ $json.trends_data }}\n\nCreate 10 short TikTok scripts that:\n1. Match the brand niche: {{ $json.brand_niche }}\n2. Use the brand voice: {{ $json.brand_voice }}\n3. Promote these products: {{ $json.products }}\n4. Are 15-60 seconds long\n5. Include a strong hook, engaging content, and clear CTA\n\nEach script should be punchy, viral-worthy, and ready to film.",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an expert TikTok content creator who understands viral trends, short-form video hooks, and brand storytelling. You MUST respond with valid JSON only. Return a JSON object with a \"scripts\" array containing exactly 10 objects. Each object must have: \"title\" (catchy title), \"script\" (full 15-60 second script text), \"hook\" (opening hook line), and \"cta\" (call to action). No markdown, no explanations, only the JSON object."
        }
      },
