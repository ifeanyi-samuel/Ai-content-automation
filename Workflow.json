    {
      "parameters": {
        "jsCode": "const output = $input.first().json.output;\nconst scripts = typeof output === \"string\" ? JSON.parse(output).scripts : output.scripts;\nreturn scripts.map((script, index) => ({\n  json: {\n    script_number: index + 1,\n    title: script.title,\n    script: script.script,\n    hook: script.hook,\n    cta: script.cta,\n    generated_at: new Date().toISOString()\n  }\n}));"
      },
      "id": "506a2652-45b7-49ff-ac19-4e4f8abcf39d",
